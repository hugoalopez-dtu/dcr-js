{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES2020",
    "lib": [
      "ESNext"
    ],
    /* Modules */
    "module": "commonjs",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  }
}